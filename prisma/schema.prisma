model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  bookings  Booking[]
}

model Hotel {
  id        Int       @id @default(autoincrement())
  name      String
  location  String
  rooms     Room[]
}

model Room {
  id           Int       @id @default(autoincrement())
  number       Int
  price        Float
  hotelId      Int
  hotel        Hotel     @relation(fields: [hotelId], references: [id])
  bookings     Booking[]
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId    Int
  roomId    Int
  user      User     @relation(fields: [userId], references: [id])
  room      Room     @relation(fields: [roomId], references: [id])
  startDate DateTime
  endDate   DateTime
}